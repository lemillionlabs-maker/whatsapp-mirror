# ── Paths ─────────────────────────────────────────────────────────────────────
DB_PATH=/data/mirror.db
SLAVE_AUTH_DIR=/data/slave-auth
MASTER_AUTH_DIR=/data/master-auth

# ── Ports ─────────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
SLAVE_PORT=3001
MASTER_PORT=3002

# ── Behavior ──────────────────────────────────────────────────────────────────
# Polling interval in ms for the master to pick up new messages
POLL_INTERVAL=2000

# Timezone for message timestamps (e.g. Africa/Accra, Africa/Lagos, UTC)
TZ=Africa/Accra

# Log level for master bot: silent | warn | info | debug
LOG_LEVEL=warn
